# Postgres connection string — REQUIRED (the indexer uses Postgres; PGlite is disabled).
# Local dev: run `docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres:16`
# then use the URL below. On Railway, reference the Postgres service: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Optional: pin the Postgres schema so the indexer and the Next.js API proxy agree
# across deploys (Ponder otherwise picks a per-deployment schema).
# DATABASE_SCHEMA=public

# Optional RPC overrides (defaults are the public endpoints in ponder.config.ts).
# PONDER_RPC_URL_25925=https://rpc-testnet.bitkubchain.io
# PONDER_RPC_URL_96=https://rpc.bitkubchain.io
# PONDER_RPC_URL_8899=https://rpc-l1.jibchain.net
